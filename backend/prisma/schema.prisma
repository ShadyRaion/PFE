model SubjectDocument {
  id String @id @default(uuid())

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  uploadedById String?

  originalName String
  fileName     String
  filePath     String
  fileType     String
  fileSize     Int

  createdAt DateTime @default(now())
}

