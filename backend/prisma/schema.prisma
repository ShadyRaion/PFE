generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  COMPANY_SUPERVISOR
  ADMIN
}

enum SupervisorStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  AFFECTED
  COMPLETED
  CANCELLED
}

enum BinomeStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum ConversationType {
  APPLICATION
  BINOME
}

enum EducationField {
  INFORMATION_TECHNOLOGY
  FINANCE_ACCOUNTING
  DATA_ANALYSIS_BI
  MANAGEMENT_HR
  MARKETING_COMMUNICATION
}

model User {
  id       String @id @default(uuid())
  fullName String
  email    String @unique
  password String
  role     Role

  university String?
  specialty  String?
  phone      String?

  educationField EducationField?

  supervisorStatus SupervisorStatus?

  // Student-specific profile fields (used when role = STUDENT)
  degreeLevel         String?
  academicYear        String?
  internshipType      String?
  internshipStartDate DateTime?
  desiredDuration     String?

  // Supervisor-specific profile fields (used when role = COMPANY_SUPERVISOR)
  department String?
  rank       String?
  division   String?

  studentConversations    Conversation[] @relation("StudentConversation")
  supervisorConversations Conversation[] @relation("SupervisorConversation")
  messages                Message[]

  applications  Application[]  @relation("StudentApplications")
  subjects      Subject[]
  cvs           CV[]
  auditLogs     AuditLog[]
  notifications Notification[]
  blacklists    Blacklist[]
  pageAlerts    PageAlert[]

  student1Binomes  Binome[] @relation("Student1Binomes")
  student2Binomes  Binome[] @relation("Student2Binomes")
  requestedBinomes Binome[] @relation("RequestedBinomes")

  recommendationScores RecommendationScore[]
  reportsFiled         IncidentReport[]      @relation("SupervisorIncidentReports")
  reportsReceived      IncidentReport[]      @relation("ReportedIncidentReports")

  academicReport       AcademicReport?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

