model Binome {
  id String @id @default(uuid())

  student1Id    String
  student2Id    String
  requestedById String

  student1    User @relation("Student1Binomes", fields: [student1Id], references: [id], onDelete: Cascade)
  student2    User @relation("Student2Binomes", fields: [student2Id], references: [id], onDelete: Cascade)
  requestedBy User @relation("RequestedBinomes", fields: [requestedById], references: [id], onDelete: Cascade)

  status BinomeStatus @default(PENDING)

  applications         Application[]
  recommendationScores RecommendationScore[]
  conversation         Conversation?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([student1Id, student2Id])
}
