PORT=5000
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/stb_interns"
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-string"
# Comma-separated list of allowed frontend origins
CORS_ORIGINS="http://localhost:5173"
# Used to build password reset links. Defaults to the first CORS origin.
FRONTEND_URL="http://localhost:5173"

# Optional SMTP settings for password reset email.
# When SMTP_HOST is empty, reset links are printed to the backend console.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="STB Interns <no-reply@stb.local>"
